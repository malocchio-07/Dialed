# Supabase (anon key is public — protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mapbox (public token — restrict it to your domain in the Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# ShadeMap (free key from https://shademap.app/about/ — powers terrain+building
# shadows). Optional: leave blank and the "Sun & shade" button stays disabled.
NEXT_PUBLIC_SHADEMAP_KEY=your_shademap_key

# OpenWeatherMap (free key from https://openweathermap.org/api — powers the
# live cloud cover map layer). Optional: leave blank and the clouds toggle
# stays disabled.
NEXT_PUBLIC_OPENWEATHER_KEY=your_openweathermap_key

# Base path. Leave unset — Cloudflare Pages serves from the domain root.
# Only set this if you ever host from a sub-path instead.
# NEXT_PUBLIC_BASE_PATH=
